mode = "recursive" # or "forwarding"

[cache]
max_entries = 10000
min_ttl_secs = 300           # floor for short upstream TTLs (improves hit rate)
negative_ttl_secs = 300      # cache NXDOMAIN/SERVFAIL responses for 5 minutes
prefetch = true              # background re-resolve entries nearing expiry
prefetch_threshold = 0.1     # prefetch when <10% of original TTL remains

[blocklist]
enabled = true
refresh_interval_hours = 24

[[blocklist.sources]]
name = "peter-lowe"
url = "https://pgl.yoyo.org/adservers/serverlist.php?hostformat=hosts&showintro=0"

[[blocklist.sources]]
name = "stevenblack"
url = "https://raw.githubusercontent.com/StevenBlack/hosts/master/hosts"

[threat]
enabled = true                    # enable AI threat detection and graylist
entropy_threshold = 3.5           # Shannon entropy threshold for flagging (0.0-5.0)
frequency_min_queries = 10        # min queries before frequency-based flagging
frequency_rate_threshold = 0.5    # queries/sec above which domain is flagged
ollama_enabled = true             # enable LLM classification via ollama
ollama_url = "http://localhost:11434"
ollama_model = "gemma2:2b"        # small model suitable for Pi 4
classification_interval_secs = 300 # classify pending domains every 5 min
classification_batch_size = 5     # how many domains per classification run

[metrics]
enabled = true
port = 9053

[tui]
tick_rate_ms = 250

# Only used in forwarding mode, or as fallback
[[upstream.servers]]
name = "quad9"
address = "9.9.9.9"
protocol = "dot"

[[upstream.servers]]
name = "cloudflare"
address = "1.1.1.1"
protocol = "doq"
