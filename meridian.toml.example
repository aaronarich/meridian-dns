mode = "recursive" # or "forwarding"

[cache]
max_entries = 10000

[blocklist]
enabled = true
refresh_interval_hours = 24

[[blocklist.sources]]
name = "peter-lowe"
url = "https://pgl.yoyo.org/adservers/serverlist.php?hostformat=hosts&showintro=0"

[[blocklist.sources]]
name = "stevenblack"
url = "https://raw.githubusercontent.com/StevenBlack/hosts/master/hosts"

[metrics]
enabled = true
port = 9053

[tui]
tick_rate_ms = 250

# Only used in forwarding mode, or as fallback
[[upstream.servers]]
name = "quad9"
address = "9.9.9.9"
protocol = "dot"

[[upstream.servers]]
name = "cloudflare"
address = "1.1.1.1"
protocol = "doq"
